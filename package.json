{
  "name": "top-todo",
  "version": "1.0.0",
  "description": "TOP To-do list project",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config webpack.prod.js",
    "dev": "webpack serve --config webpack.dev.js",
    "deploy": "git switch gh-pages && git merge main --no-edit && npm run build && git add dist -f && git commit -m 'Deployment commit' && git subtree push --prefix dist origin gh-pages && git checkout main",
    "first-deploy": "git branch gh-pages && npm run deploy",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
